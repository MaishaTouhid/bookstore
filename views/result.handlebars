<h2 class="mb-4"> All Books </h2>

<a href="/" class="btn btn-primary mb-3"> Add New Book </a>

<!-- Search Form -->
<form action="/search" method="GET" class="mb-3">
    <div class="input-group">
        <input
            type="text"
            class="form-control"
            name="keyword"
            placeholder="Search by Title or Author"
        >
        <button class="btn btn-success" type="submit">
            Search
        </button>
    </div>
</form>
<!-- end here -->
{{#if searchResults}}
    <h4>Search Results:</h4>
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Author</th>
                <th>Publisher</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            {{#each searchResults}}
                <tr>
                    <td>{{id}}</td>
                    <td>{{title}}</td>
                    <td>{{author}}</td>
                    <td>{{publisher}}</td>
                    <td>{{price}}</td>
                    <td>{{quantity}}</td>
                    <td>
                        <a href="/edit/{{id}}" class="btn btn-warning btn-sm"> Edit </a>
                        <a href="/delete/{{id}}" class="btn btn-danger btn-sm"> Delete </a>
                    </td>
                </tr>
            {{/each}}
        </tbody>
    </table>
{{/if}}


<table class="table table-bordered table-hover">
<thead class="table-dark">

<tr>

<th>ID</th>
