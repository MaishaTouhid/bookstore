<h2 class="mb-4"> All Books </h2>

<a href="/" class="btn btn-primary mb-3"> Add New Book </a>

<table class="table table-bordered table-hover">
<thead class="table-dark">

<tr>

<th>ID</th>
<th>Title</th>
<th>Author</th>
<th>Publisher</th>
<th>Price</th>
<th>Quantity</th>
<th>Action</th>

</tr>

</thead>

<tbody>

{{#each books}}

<tr>

<td>{{id}}</td>

<td>{{title}}</td>

<td>{{author}}</td>

<td>{{publisher}}</td>

<td>{{price}}</td>

<td>{{quantity}}</td>

<td>

<a href="/edit/{{id}}" class="btn btn-warning btn-sm"> Edit </a>

<a href="/delete/{{id}}" class="btn btn-danger btn-sm"> Delete </a>

</td>

</tr>

{{/each}}

</tbody>

</table>