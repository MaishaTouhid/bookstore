<div class="card shadow p-4">

<h2 class="text-center mb-4">

Book Information Form

</h2>

<form action="/submit" method="POST">

<div class="mb-3">

<label>Book Title</label>

<input
type="text"
class="form-control"
name="title"
required>

</div>

<div class="mb-3">

<label>Author</label>

<input
type="text"
class="form-control"
name="author"
required>

</div>

<div class="mb-3">

<label>Publisher</label>

<input
type="text"
class="form-control"
name="publisher"
required>

</div>

<div class="mb-3">

<label>Price</label>

<input
type="number"
class="form-control"
name="price"
required>

</div>

<div class="mb-3">

<label>Quantity</label>

<input
type="number"
class="form-control"
name="quantity"
required>

</div>

<button class="btn btn-primary w-100">

Save Book

</button>

</form>

<hr>

<a href="/books" class="btn btn-success w-100">

View All Books

</a>

</div>